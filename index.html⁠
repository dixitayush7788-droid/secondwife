        function scrollToSection(id, element) {
            const target = document.getElementById(id);
            if(target) { window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 138, behavior: 'smooth' }); }
            document.querySelectorAll('.category-pill').forEach(p => p.className = "category-pill px-4 py-2.5 rounded-xl text-xs font-bold border border-white/5 text-slate-400 bg-slate-900/40");
            element.className = "category-pill active-pill px-4 py-2.5 rounded-xl text-xs font-bold border border-white/5";
        }

        function renderMenu() {
            fullMenu.forEach(item => {
                const container = document.getElementById(`${item.cat}-container`);
                if(!container) return;
                container.innerHTML += `
                    <div class="dish-card glow-card bg-[#0b1329]/40 border border-white/[0.02] p-4 rounded-2xl flex justify-between items-center transition-all duration-300 transform hover:-translate-y-1" data-name="${item.name.toLowerCase()}">
                        <div>
                            <h3 class="font-bold text-slate-100 text-xs md:text-sm tracking-tight">${item.name}</h3>
                            <p class="text-orange-500 font-extrabold text-sm mt-1">₹${item.price}</p>
                        </div>
                        <div class="flex items-center gap-2.5">
                            <button onclick="changeQty(${item.id}, -1)" id="minus-${item.id}" class="w-8 h-8 bg-slate-800 text-slate-200 font-extrabold rounded-xl hidden">-</button>
                            <span id="qty-${item.id}" class="font-black text-xs text-white hidden">0</span>
                            <button onclick="changeQty(${item.id}, 1)" class="w-10 h-10 bg-gradient-to-br from-orange-500 to-red-500 text-white font-black text-sm rounded-xl flex items-center justify-center transition-all duration-200 hover:scale-105 active:scale-[0.88] shadow-md shadow-orange-500/10">
                                <i class="fa-solid fa-plus text-xs"></i>
                            </button>
                        </div>
                    </div>
                `;
            });
        }

        function changeQty(id, delta) {
            const item = fullMenu.find(i => i.id === id);
            if (!window.cart[id]) window.cart[id] = { name: item.name, price: item.price, qty: 0 };
            window.cart[id].qty += delta;
            if (window.cart[id].qty <= 0) delete window.cart[id];
            updateCartUI(id, delta);
        }

        function updateCartUI(id, delta) {
            const qtyText = document.getElementById(`qty-${id}`);
            const minusBtn = document.getElementById(`minus-${id}`);
            const currentQty = window.cart[id] ? window.cart[id].qty : 0;

            if (qtyText && minusBtn) {
                if (currentQty > 0) {
                    qtyText.innerText = currentQty;
                    qtyText.classList.remove('hidden');
                    minusBtn.classList.remove('hidden');
                } else {
                    qtyText.classList.add('hidden');
                    minusBtn.classList.add('hidden');
                }
            }

            let totalItems = 0;
            let totalPrice = 0;
            Object.keys(window.cart).forEach(key => {
                totalItems += window.cart[key].qty;
                totalPrice += (window.cart[key].price * window.cart[key].qty);
            });

            const badge = document.getElementById('cart-count');
            const bar = document.getElementById('checkout-bar');
            
            if (totalItems > 0) {
                badge.innerText = totalItems;
                badge.classList.remove('hidden');
                if (delta > 0) { bar.classList.remove('translate-y-full'); }
                document.getElementById('cart-summary').innerText = `${totalItems} ${totalItems === 1 ? 'Dish' : 'Dishes'} Selected`;
                document.getElementById('cart-total').innerText = `₹${totalPrice}`;
            } else {
                badge.classList.add('hidden');
                bar.classList.add('translate-y-full');
            }

            const pBar = document.getElementById('delivery-progress');
            const msg = document.getElementById('delivery-msg');
            if(totalPrice < 100) {
                pBar.style.width = `${totalPrice}%`;
                msg.innerHTML = `Shop ₹${100 - totalPrice} more to unlock delivery`;
            } else if (totalPrice < 299) {
                pBar.style.width = `${(totalPrice/299)*100}%`;
                msg.innerHTML = `Add ₹${299 - totalPrice} for FREE delivery!`;
            } else {
                pBar.style.width = '100%';
                msg.innerHTML = "🎉 FREE delivery unlocked!";
            }
            validateOnlineLock();
        }

        function openCartDrawer() { if (Object.keys(window.cart).length > 0) document.getElementById('checkout-bar').classList.remove('translate-y-full'); }
        function closeCartDrawer() { document.getElementById('checkout-bar').classList.add('translate-y-full'); }

        function togglePaymentView(method) {
            window.selectedMethod = method;
            const payBlock = document.getElementById('online-pay-block');
            if (method === 'Online') {
                payBlock.classList.remove('hidden');
                document.getElementById('label-online').className = "flex items-center justify-center gap-2 bg-slate-900/80 border-2 border-orange-500 p-3.5 rounded-2xl cursor-pointer";
                document.getElementById('label-cod').className = "flex items-center justify-center gap-2 bg-slate-900/50 border-2 border-white/5 p-3.5 rounded-2xl cursor-pointer";
            } else {
                payBlock.classList.add('hidden');
                document.getElementById('label-cod').className = "flex items-center justify-center gap-2 bg-slate-900/80 border-2 border-orange-500 p-3.5 rounded-2xl cursor-pointer";
                document.getElementById('label-online').className = "flex items-center justify-center gap-2 bg-slate-900/50 border-2 border-white/5 p-3.5 rounded-2xl cursor-pointer";
            }
            validateOnlineLock();
        }

        function validateOnlineLock() {
            const btn = document.getElementById('checkout-btn');
            const utrInput = document.getElementById('utr-input').value.trim();
            if (window.selectedMethod === 'Online' && utrInput.length < 4) {
                btn.disabled = true;
                btn.className = "w-full max-w-md bg-slate-800 text-slate-500 py-4.5 rounded-2xl font-bold text-xs flex items-center justify-center gap-3 cursor-not-allowed opacity-60";
            } else {
                btn.disabled = false;
                btn.className = "secure-pulse w-full max-w-md bg-gradient-to-r from-emerald-500 to-green-600 text-black py-4.5 rounded-2xl font-extrabold text-xs flex items-center justify-center gap-3 tracking-wide";
            }
        }

        function searchDish() {
            const input = document.getElementById('search-bar').value.toLowerCase();
            const cards = document.getElementsByClassName('dish-card');
            for (let i = 0; i < cards.length; i++) { cards[i].style.display = cards[i].getAttribute('data-name').includes(input) ? "flex" : "none"; }
        }

        window.onload = renderMenu;
    </script>
