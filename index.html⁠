    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

        const firebaseConfig = { databaseURL: "https://secondwife-1cd1d-default-rtdb.firebaseio.com/" };
        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);

        window.sendOrder = function() {
            let totalBill = 0;
            Object.keys(window.cart).forEach(key => totalBill += (window.cart[key].price * window.cart[key].qty));
            if(totalBill < 100) { alert(`Minimum order threshold is ₹100.`); return; }

            const orderId = "SW-" + Math.floor(100000 + Math.random() * 900000);
            let itemsString = "";
            Object.keys(window.cart).forEach(key => { itemsString += `${window.cart[key].name} (x${window.cart[key].qty}), `; });

            // Fixed window explicit scope resolution mapping for strict mode compatibility
            const utrVal = window.selectedMethod === 'Online' ? document.getElementById('utr-input').value.trim() : "COD_MODE";

            set(ref(db, 'orders/' + orderId), {
                id: orderId,
                items: itemsString,
                total: totalBill,
                payment: window.selectedMethod,
                utr: utrVal,
                status: "placed",
                prepTime: 0,
                timestamp: Date.now()
            }).then(() => {
                document.getElementById('store-front-view').classList.add('hidden');
                document.getElementById('checkout-bar').classList.add('translate-y-full');
                document.getElementById('tracking-screen-view').classList.remove('hidden');
                document.getElementById('track-order-id').innerText = `Order ID: ${orderId}`;
                
                listenToOrderLive(orderId);
                
                let whatsappText = `🍽️ *NEW ONLINE ORDER - SECOND WIFE*%0AOrder ID: *${orderId}*%0AItems: ${itemsString}%0AMode: ${window.selectedMethod}%0ATotal: ₹${totalBill}`;
                window.open(`https://wa.me/918467895365?text=${whatsappText}`, '_blank');
            });
        }

        function listenToOrderLive(orderId) {
            onValue(ref(db, 'orders/' + orderId), (snapshot) => {
                const data = snapshot.val();
                if(!data) return;

                const status = data.status;
                const pCard = document.getElementById('status-card-glow');

                resetTrackingUIVisuals();

                if(status === 'placed') {
                    activateTrackingStep('step-placed', 'icon-placed', 'bg-amber-500');
                    pCard.className = "absolute top-0 right-0 w-32 h-32 bg-amber-500/10 rounded-full blur-2xl";
                } else if(status === 'cooking') {
                    activateTrackingStep('step-placed', 'icon-placed', 'bg-emerald-500');
                    activateTrackingStep('step-cooking', 'icon-cooking', 'bg-amber-500 text-black');
                    pCard.className = "absolute top-0 right-0 w-32 h-32 bg-orange-500/20 rounded-full blur-2xl";
                    if(data.prepTime > 0) {
                        document.getElementById('cooking-timer-text').innerHTML = `🔥 Chef are cooking. *Estimated completion time: ${data.prepTime} Mins*`;
                    }
                } else if(status === 'dispatched') {
                    activateTrackingStep('step-placed', 'icon-placed', 'bg-emerald-500');
                    activateTrackingStep('step-cooking', 'icon-cooking', 'bg-emerald-500');
                    activateTrackingStep('step-dispatched', 'icon-dispatched', 'bg-blue-500');
                    pCard.className = "absolute top-0 right-0 w-32 h-32 bg-blue-500/20 rounded-full blur-2xl";
                } else if(status === 'delivered') {
                    activateTrackingStep('step-placed', 'icon-placed', 'bg-emerald-500');
                    activateTrackingStep('step-cooking', 'icon-cooking', 'bg-emerald-500');
                    activateTrackingStep('step-dispatched', 'icon-dispatched', 'bg-emerald-500');
                    activateTrackingStep('step-delivered', 'icon-delivered', 'bg-emerald-500 text-black secure-pulse');
                    pCard.className = "absolute top-0 right-0 w-32 h-32 bg-emerald-500/20 rounded-full blur-2xl";
                }
            });
        }

        function resetTrackingUIVisuals() {
            ['step-placed', 'step-cooking', 'step-dispatched', 'step-delivered'].forEach(id => { document.getElementById(id).classList.add('opacity-40'); });
            ['icon-placed', 'icon-cooking', 'icon-dispatched', 'icon-delivered'].forEach((id) => { document.getElementById(id).className = "w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center font-bold text-sm text-white flex-shrink-0"; });
        }

        function activateTrackingStep(stepId, iconId, bgClass) {
            document.getElementById(stepId).classList.remove('opacity-40');
            document.getElementById(iconId).className = `w-8 h-8 rounded-full ${bgClass} flex items-center justify-center font-black text-sm text-black flex-shrink-0`;
        }
    </script>

